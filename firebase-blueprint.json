{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A furniture item for sale",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "stock": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "description", "price", "category", "image"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer purchase order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerDetails": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" }
          }
        },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "customerDetails", "items", "total", "status"]
    },
    "Message": {
      "title": "Message",
      "description": "A contact message from a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message"]
    },
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Collection of furniture products"
    },
    "orders": {
      "schema": "Order",
      "description": "Collection of customer orders"
    },
    "messages": {
      "schema": "Message",
      "description": "Collection of contact inquiries"
    },
    "users": {
      "schema": "User",
      "description": "Collection of user profile records"
    }
  }
}
